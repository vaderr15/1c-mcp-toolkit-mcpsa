Функция СтрокаНачинаетсяС(Строка, НачальнаяПодстрока)
	
	// Совместимая функция для проверки начала строки
	Возврат Лев(Строка, СтрДлина(НачальнаяПодстрока)) = НачальнаяПодстрока;
	
КонецФункции

Функция ЭтоСсылочныйТип(ТипЗначения)
	
	// Проверка на ссылочные типы, совместимая с толстым клиентом
	ИмяТипа = Строка(ТипЗначения);
	
	Возврат СтрокаНачинаетсяС(ИмяТипа, "СправочникСсылка.")
		Или СтрокаНачинаетсяС(ИмяТипа, "ДокументСсылка.")
		Или СтрокаНачинаетсяС(ИмяТипа, "ПланВидовХарактеристикСсылка.")
		Или СтрокаНачинаетсяС(ИмяТипа, "ПланСчетовСсылка.")
		Или СтрокаНачинаетсяС(ИмяТипа, "ПланВидовРасчетаСсылка.")
		Или СтрокаНачинаетсяС(ИмяТипа, "БизнесПроцессСсылка.")
		Или СтрокаНачинаетсяС(ИмяТипа, "ЗадачаСсылка.");
	
КонецФункции

Функция ЗаписатьJSONСовместимо(Объект)
	
	Попытка
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, Объект);
		Результат = ЗаписьJSON.Закрыть();
		Возврат Результат;
	Исключение
		Возврат "";
	КонецПопытки;
	
КонецФункции

Функция ПрочитатьJSONСовместимо(СтрокаJSON)
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
		Результат = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		Возврат Результат;
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

// ─────────────────────────────────────────────────────────────────────────────────
// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
// ─────────────────────────────────────────────────────────────────────────────────

Функция БезопасноеЗначениеДляПередачи(Значение, Глубина = 0)
	
	Если Глубина > 5 Тогда
		Возврат "<max_depth>";
	КонецЕсли;
	
	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТипЗначения = ТипЗнч(Значение);
	
	Если ТипЗначения = Тип("Строка")
		Или ТипЗначения = Тип("Число")
		Или ТипЗначения = Тип("Булево")
		Или ТипЗначения = Тип("Дата") Тогда
		Возврат Значение;
	КонецЕсли;
	
	Если ТипЗначения = Тип("УникальныйИдентификатор") Тогда
		Возврат Строка(Значение);
	КонецЕсли;
	
	// Проверка на ссылочный тип (совместимо с толстым клиентом)
	Если ЭтоСсылочныйТип(ТипЗначения) Тогда
		Если ЗначениеЗаполнено(Значение) Тогда
			Возврат Новый Структура("Ссылка, Представление", Значение, Строка(Значение));
		Иначе
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗначения = Тип("Массив") Тогда
		Результат = Новый Массив;
		Для Каждого Элемент Из Значение Цикл
			Результат.Добавить(БезопасноеЗначениеДляПередачи(Элемент, Глубина + 1));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗначения = Тип("Структура") Тогда
		Результат = Новый Структура;
		Для Каждого Пара Из Значение Цикл
			Результат.Вставить(Пара.Ключ, БезопасноеЗначениеДляПередачи(Пара.Значение, Глубина + 1));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗначения = Тип("ТаблицаЗначений") Тогда
		Результат = Новый Массив;
		Для Каждого СтрокаТаблицы Из Значение Цикл
			СтрокаРезультата = Новый Структура;
			Для Каждого Колонка Из Значение.Колонки Цикл
				СтрокаРезультата.Вставить(Колонка.Имя, БезопасноеЗначениеДляПередачи(СтрокаТаблицы[Колонка.Имя], Глубина + 1));
			КонецЦикла;
			Результат.Добавить(СтрокаРезультата);
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;
	
	// Для остальных типов возвращаем строковое представление
	Возврат Строка(Значение);
	
КонецФункции

Функция ПрочитатьДатуИзISO(СтрокаДаты)
	
	Попытка
		// Упрощенный парсинг ISO даты
		Если ПустаяСтрока(СтрокаДаты) Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		// Попытка прочитать как дату
		Возврат XMLЗначение(Тип("Дата"), СтрокаДаты);
		
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции
Функция ПолучитьТекстКоманды(Команда)
	
	ТекстКоманды = "";
	Отступ = "    "; // 4 пробела
	
	Если Не Команда.Свойство("params") Или Команда.params = Неопределено Тогда
		Возврат Отступ + "(без параметров)";
	КонецЕсли;
	
	ПараметрыКоманды = Команда.params;
	
	Если Команда.tool = "execute_query" Тогда
		Если ПараметрыКоманды.Свойство("query") Тогда
			ТекстКоманды = ПараметрыКоманды.query;
		КонецЕсли;
	ИначеЕсли Команда.tool = "execute_code" Тогда
		Если ПараметрыКоманды.Свойство("code") Тогда
			ТекстКоманды = ПараметрыКоманды.code;
		КонецЕсли;
	ИначеЕсли Команда.tool = "get_metadata" Тогда
		ЧастиТекста = Новый Массив;
		Если ПараметрыКоманды.Свойство("filter") И Не ПустаяСтрока(ПараметрыКоманды.filter) Тогда
			ЧастиТекста.Добавить("фильтр: " + ПараметрыКоманды.filter);
		КонецЕсли;
		Если ПараметрыКоманды.Свойство("meta_type") И Не ПустаяСтрока(ПараметрыКоманды.meta_type) Тогда
			ЧастиТекста.Добавить("тип: " + ПараметрыКоманды.meta_type);
		КонецЕсли;
		Если ПараметрыКоманды.Свойство("name_mask") И Не ПустаяСтрока(ПараметрыКоманды.name_mask) Тогда
			ЧастиТекста.Добавить("маска: " + ПараметрыКоманды.name_mask);
		КонецЕсли;
		Если ЧастиТекста.Количество() = 0 Тогда
			ТекстКоманды = "(все метаданные)";
		Иначе
			ТекстКоманды = СоединитьМассив(ЧастиТекста, ", ");
		КонецЕсли;
	ИначеЕсли Команда.tool = "get_event_log" Тогда
		ЧастиТекста = Новый Массив;
		Если ПараметрыКоманды.Свойство("start_date") И Не ПустаяСтрока(ПараметрыКоманды.start_date) Тогда
			ЧастиТекста.Добавить("с: " + ПараметрыКоманды.start_date);
		КонецЕсли;
		Если ПараметрыКоманды.Свойство("end_date") И Не ПустаяСтрока(ПараметрыКоманды.end_date) Тогда
			ЧастиТекста.Добавить("по: " + ПараметрыКоманды.end_date);
		КонецЕсли;
		Если ПараметрыКоманды.Свойство("limit") Тогда
			ЧастиТекста.Добавить("лимит: " + ПараметрыКоманды.limit);
		КонецЕсли;
		Если ЧастиТекста.Количество() = 0 Тогда
			ТекстКоманды = "(весь журнал)";
		Иначе
			ТекстКоманды = СоединитьМассив(ЧастиТекста, ", ");
		КонецЕсли;
	ИначеЕсли Команда.tool = "get_object_by_link" Тогда
		Если ПараметрыКоманды.Свойство("link") Тогда
			ТекстКоманды = "ссылка: " + ПараметрыКоманды.link;
		Иначе
			ТекстКоманды = "(без ссылки)";
		КонецЕсли;
	ИначеЕсли Команда.tool = "get_link_of_object" Тогда
		Если ПараметрыКоманды.Свойство("object_description") И ПараметрыКоманды.object_description.Свойство("Представление") Тогда
			ТекстКоманды = "объект: " + ПараметрыКоманды.object_description.Представление;
		Иначе
			ТекстКоманды = "(описание объекта)";
		КонецЕсли;
	ИначеЕсли Команда.tool = "find_references_to_object" Тогда
		ЧастиТекста = Новый Массив;
		Если ПараметрыКоманды.Свойство("target_object_description") И ПараметрыКоманды.target_object_description.Свойство("Представление") Тогда
			ЧастиТекста.Добавить("объект: " + ПараметрыКоманды.target_object_description.Представление);
		КонецЕсли;
		Если ПараметрыКоманды.Свойство("search_scope") И ТипЗнч(ПараметрыКоманды.search_scope) = Тип("Массив") Тогда
			ЧастиТекста.Добавить("области: " + СоединитьМассив(ПараметрыКоманды.search_scope, ", "));
		КонецЕсли;
		Если ЧастиТекста.Количество() = 0 Тогда
			ТекстКоманды = "(поиск ссылок)";
		Иначе
			ТекстКоманды = СоединитьМассив(ЧастиТекста, ", ");
		КонецЕсли;
	ИначеЕсли Команда.tool = "get_access_rights" Тогда
		Если ПараметрыКоманды.Свойство("metadata_object") Тогда
			ТекстКоманды = "объект: " + ПараметрыКоманды.metadata_object;
		Иначе
			ТекстКоманды = "(права доступа)";
		КонецЕсли;
	Иначе
		ТекстКоманды = "(неизвестная команда)";
	КонецЕсли;
	
	// Преобразуем экранированные символы
	ТекстКоманды = СтрЗаменить(ТекстКоманды, "\r", "");
	ТекстКоманды = СтрЗаменить(ТекстКоманды, "\t", "    ");
	ТекстКоманды = СтрЗаменить(ТекстКоманды, "\n", Символы.ПС);
	
	// Добавляем отступ к каждой строке
	ТекстКоманды = Отступ + СтрЗаменить(ТекстКоманды, Символы.ПС, Символы.ПС + Отступ);
	
	Возврат ТекстКоманды;
	
КонецФункции

Функция ПолучитьТекстРезультата(Результат)
	
	Отступ = "    "; // 4 пробела
	ТекстРезультата = "";
	
	Если Результат.Свойство("success") И Результат.success = Истина Тогда
		Если Результат.Свойство("data") Тогда
			ТекстРезультата = ЗаписатьJSONСовместимо(Результат.data);
		Иначе
			ТекстРезультата = "(нет данных)";
		КонецЕсли;
	Иначе
		Если Результат.Свойство("error") Тогда
			ТекстРезультата = "Ошибка: " + Результат.error;
		Иначе
			ТекстРезультата = "(неизвестная ошибка)";
		КонецЕсли;
	КонецЕсли;
	
	// Преобразуем экранированные символы
	ТекстРезультата = СтрЗаменить(ТекстРезультата, "\r", "");
	ТекстРезультата = СтрЗаменить(ТекстРезультата, "\t", "    ");
	ТекстРезультата = СтрЗаменить(ТекстРезультата, "\n", Символы.ПС);
	
	// Добавляем отступ к каждой строке
	ТекстРезультата = Отступ + СтрЗаменить(ТекстРезультата, Символы.ПС, Символы.ПС + Отступ);
	
	Возврат ТекстРезультата;
	
КонецФункции

Процедура УстановитьСтатус(НовыйСтатус, ФлагПодключения)
	
	Статус = НовыйСтатус;
	Подключено = ФлагПодключения;
	
КонецПроцедуры

Процедура ДобавитьВЛог(Сообщение)
	
	ТекДата = ТекущаяДата();
	ВремяСообщения = Строка(ТекДата);
	НовоеСообщение = "[" + ВремяСообщения + "] " + Сообщение;
	
	// Вставляем строку в начало текстового документа (новые сообщения вверху)
	ЛогДокумент.ВставитьСтроку(1, НовоеСообщение);
	
	// Ограничиваем количество строк в логе (например, 1000 строк)
	// Удаляем последние строки, если превышен лимит
	Если ЛогДокумент.КоличествоСтрок() > 1000 Тогда
		ЛогДокумент.УдалитьСтроку(ЛогДокумент.КоличествоСтрок());
	КонецЕсли;
	
	// Обновляем отображение в элементе формы
	ЭлементыФормы.Лог.УстановитьТекст(ЛогДокумент.ПолучитьТекст());
	
КонецПроцедуры

Процедура ЗагрузитьНастройки()
	
	// Загрузка настроек из хранилища общих настроек
	Попытка
		НастройкиИзХранилища = ХранилищеОбщихНастроек.Загрузить("MCPToolkit", "НастройкиПодключения");
		
		Если ТипЗнч(НастройкиИзХранилища) = Тип("Структура") Тогда
			Если НастройкиИзХранилища.Свойство("АдресСервера") И ЗначениеЗаполнено(НастройкиИзХранилища.АдресСервера) Тогда
				АдресСервера = НастройкиИзХранилища.АдресСервера;
			КонецЕсли;
			
			Если НастройкиИзХранилища.Свойство("ИдентификаторКанала") Тогда
				ИдентификаторКанала = НастройкиИзХранилища.ИдентификаторКанала;
			КонецЕсли;
			
			Если НастройкиИзХранилища.Свойство("АвтоРазрешитьЗаписать") Тогда
				АвтоРазрешитьЗаписать = НастройкиИзХранилища.АвтоРазрешитьЗаписать;
			КонецЕсли;
			
			Если НастройкиИзХранилища.Свойство("АвтоРазрешитьПривилегированныйРежим") Тогда
				АвтоРазрешитьПривилегированныйРежим = НастройкиИзХранилища.АвтоРазрешитьПривилегированныйРежим;
			КонецЕсли;
		КонецЕсли;
	Исключение
		// Игнорируем ошибки загрузки настроек
	КонецПопытки;
	
	// Значения по умолчанию если не загрузились
	Если ПустаяСтрока(АдресСервера) Тогда
		АдресСервера = "http://localhost:6003";
	КонецЕсли;
	
	Если ИдентификаторКанала = Неопределено Тогда
		ИдентификаторКанала = "";
	КонецЕсли;
	
КонецПроцедуры

Процедура СохранитьНастройки()
	
	// Сохранение настроек в хранилище общих настроек
	Попытка
		НастройкиДляСохранения = Новый Структура;
		НастройкиДляСохранения.Вставить("АдресСервера", АдресСервера);
		НастройкиДляСохранения.Вставить("ИдентификаторКанала", ИдентификаторКанала);
		НастройкиДляСохранения.Вставить("АвтоРазрешитьЗаписать", АвтоРазрешитьЗаписать);
		НастройкиДляСохранения.Вставить("АвтоРазрешитьПривилегированныйРежим", АвтоРазрешитьПривилегированныйРежим);
		
		ХранилищеОбщихНастроек.Сохранить("MCPToolkit", "НастройкиПодключения", НастройкиДляСохранения);
	Исключение
		// Игнорируем ошибки сохранения настроек
	КонецПопытки;
	
КонецПроцедуры

Функция СоединитьМассив(Массив, Разделитель)
	
	Результат = "";
	Для Индекс = 0 По Массив.Количество() - 1 Цикл
		Если Индекс > 0 Тогда
			Результат = Результат + Разделитель;
		КонецЕсли;
		Результат = Результат + Строка(Массив[Индекс]);
	КонецЦикла;
	Возврат Результат;
	
КонецФункции

